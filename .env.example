# ============================================================
# SISTRO Next.js - Environment Variables
# Salin file ini menjadi .env.local untuk development
# ============================================================

# URL ASP.NET backend (tanpa trailing slash)
# Dev/testing  : http://192.168.188.170:8090
# Production   : https://sistro.pupuk-indonesia.com
ASPNET_API_URL=http://192.168.188.170:8090

# Next.js public URL (dipakai next-auth callback)
NEXTAUTH_URL=http://localhost:3000

# Secret untuk signing JWT next-auth (ganti dengan random string di production)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=ganti-dengan-random-string-yang-panjang

# ============================================================
# Variabel berikut TIDAK diperlukan lagi di branch ini
# (dulunya untuk koneksi PostgreSQL langsung)
# DATABASE_URL=
# POSTGRES_HOST=
# ============================================================
