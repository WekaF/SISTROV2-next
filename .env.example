# ============================================================
# SISTRO Next.js - Environment Variables
# Salin file ini menjadi .env.local untuk development
# ============================================================

# URL ASP.NET backend (tanpa trailing slash)
# Dev/testing  : http://192.168.188.170:8090
# Production   : https://sistro.pupuk-indonesia.com
ASPNET_API_URL=http://192.168.188.170:8090
NEXT_PUBLIC_ASPNET_API_URL=http://192.168.188.170:8090

# Next.js public URL (dipakai next-auth callback)
NEXTAUTH_URL=http://localhost:3000

# Secret untuk signing JWT next-auth (ganti dengan random string di production)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=ganti-dengan-random-string-yang-panjang

# Separate PostgreSQL database for Next.js activity logging
# Create DB first: CREATE DATABASE sistro_logs;
LOG_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/sistro_logs

# ============================================================
# Variabel berikut TIDAK diperlukan lagi di branch ini
# (dulunya untuk koneksi PostgreSQL langsung)
# DATABASE_URL=
# POSTGRES_HOST=
# ============================================================

# ============================================================
# CI/CD & Notifications (untuk GitHub Actions Secrets — bukan .env.local)
# Variabel ini TIDAK dipakai di aplikasi, hanya di GitHub Actions
# ============================================================
# VERCEL_TOKEN=          → Vercel account token
# VERCEL_ORG_ID=         → Vercel org/team ID
# VERCEL_PROJECT_ID=     → Vercel project ID
# WA_PHONE=6281234567890 → Nomor HP (format internasional, tanpa +)
# WA_APIKEY=             → API key dari CallMeBot
